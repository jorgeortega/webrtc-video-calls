{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/server",
    "rootDir": "./server",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["node"],
    "allowJs": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false
  },
  "include": ["server/**/*.ts"]
}
